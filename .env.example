# Podcast Creator Agent - Environment Configuration

# ====================
# Required API Keys
# ====================
# You need at least ONE of these API keys

# OpenAI API Key (for OpenAI LLM and TTS)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for Gemini LLM and TTS)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ====================
# Provider Selection (Optional)
# ====================
# Choose which provider to use for LLM and TTS
# If not specified, defaults to OpenAI (for backward compatibility)

# LLM Provider: "openai" or "gemini"
# PODCAST_LLM_PROVIDER=openai

# TTS Provider: "openai" or "gemini"
# PODCAST_TTS_PROVIDER=openai

# ====================
# Model Override (Optional)
# ====================
# Override the default models for each provider

# LLM Model Override
# OpenAI options: gpt-4.1-mini, gpt-4-turbo, etc.
# Gemini options: gemini-1.5-flash, gemini-1.5-pro, etc.
# PODCAST_LLM_MODEL=gemini-1.5-flash

# TTS Model Override
# OpenAI options: gpt-4o-mini-tts, tts-1, tts-1-hd
# Gemini options: gemini-2.5-flash, etc.
# PODCAST_TTS_MODEL=gpt-4o-mini-tts

# ====================
# Example Configurations
# ====================

# Configuration 1: Pure OpenAI (default, backward compatible)
# OPENAI_API_KEY=sk-...
# (No other settings needed)

# Configuration 2: Pure Gemini (lowest cost)
# GOOGLE_API_KEY=...
# PODCAST_LLM_PROVIDER=gemini
# PODCAST_TTS_PROVIDER=gemini

# Configuration 3: Hybrid (recommended - 90% cost savings on LLM)
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# PODCAST_LLM_PROVIDER=gemini
# PODCAST_TTS_PROVIDER=openai

# Configuration 4: Gemini LLM only (will auto-fallback to OpenAI TTS)
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# PODCAST_LLM_PROVIDER=gemini
